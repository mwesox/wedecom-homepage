        <p>
          Wedecom Consulting GmbH<br />
          Estostr. 13A<br />
          82140 Olching
        </p>
      </div>
    </Section>

    <Section label="Vertreten durch" id="vertreten">
      <div class="md-prose">
        <p>Matthias Wesolowski</p>
      </div>
    </Section>

    <Section label="Kontakt" id="kontakt">
      <div class="md-prose">
